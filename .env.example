# ============================================================
# VARIÁVEIS DE AMBIENTE — DRA. LUCIANA J. R. PINHO
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Banco de dados (SQLite para dev, PostgreSQL/Neon para produção)
DATABASE_URL="file:./dev.db"

# Segredo JWT — OBRIGATÓRIO (mínimo 32 caracteres)
JWT_SECRET="GERE_UM_SECRET_SEGURO_AQUI"

# Chave para registrar novos usuários admin
ADMIN_KEY="SUA_CHAVE_ADMIN"

# URL pública do site
NEXT_PUBLIC_APP_URL="https://dralucianajrpinho.vercel.app"
NEXT_PUBLIC_SITE_URL="https://dralucianajrpinho.vercel.app"

# WhatsApp
NEXT_PUBLIC_WHATSAPP="556599113429"

# E-mail de contato
NEXT_PUBLIC_CONTACT_EMAIL="contato@lucianapinho.adv.br"

# ============================================================
# CLOUDINARY — Hospedagem de Imagens
# Obtenha em: https://cloudinary.com/console
# ============================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="SEU_CLOUD_NAME"
CLOUDINARY_API_KEY="SUA_API_KEY"
CLOUDINARY_API_SECRET="SEU_API_SECRET"

# ============================================================
# GOOGLE CALENDAR (Opcional — para agendamento)
# ============================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
